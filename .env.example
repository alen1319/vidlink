# ── yt-dlp ─────────────────────────────────────────────
# Path to the yt-dlp binary (defaults to "yt-dlp" on PATH).
YT_DLP_PATH=yt-dlp

# ── Google AdSense ─────────────────────────────────────
# Publisher id, e.g. ca-pub-1234567890123456. When set, the AdSense loader
# and real <ins> ad units activate automatically.
NEXT_PUBLIC_ADSENSE_CLIENT=
# Per-slot ad unit ids (from your AdSense dashboard).
NEXT_PUBLIC_ADSENSE_SLOT_TOP=
NEXT_PUBLIC_ADSENSE_SLOT_BOTTOM=

# ── Anti-abuse limits (all optional; sensible defaults) ─
# Max downloadable video length, seconds (default 10800 = 3h).
MAX_DURATION_SEC=10800
# Hard per-file size cap passed to yt-dlp (default 2G).
MAX_FILESIZE=2G
# Simultaneous downloads across the process (default 3).
MAX_CONCURRENT_DOWNLOADS=3
# How many requests may wait for a slot before 503 (default 12).
MAX_DOWNLOAD_QUEUE=12
# Rate limits per IP (requests per window).
PARSE_RATE_WINDOW_MS=60000
PARSE_RATE_MAX=20
DL_RATE_WINDOW_MS=60000
DL_RATE_MAX=8
